

class Book:
    def __init__(self, book_id: str, title: str, author: str):
        self.book_id = book_id      # Book Unique ID
        self.title = title          # Book Title
        self.author = author        # Book Author
        self.is_borrowed = False    # Borrow Status

    def __str__(self):
        return f"[{self.book_id}] {self.title} - {self.author} (Status: {'Borrowed' if self.is_borrowed else 'Available'})"

class User:
    def __init__(self, user_id: str, name: str):
        self.user_id = user_id          # User Unique ID
        self.name = name                # User Name
        self.borrowed_books = []        # Borrowed Book List

    def borrow_book(self, book: Book):
        """User borrows a book"""
        if book not in self.borrowed_books:
            self.borrowed_books.append(book)
            book.is_borrowed = True

    def return_book(self, book: Book):
        """User returns a book"""
        if book in self.borrowed_books:
            self.borrowed_books.remove(book)
            book.is_borrowed = False

    def __str__(self):
        return f"User {self.name} (ID: {self.user_id}), Borrowed: {len(self.borrowed_books)} books"


class Library:
    def __init__(self):
        self.books = {}   # Book Library: {book_id: Book Object}
        self.users = {}   # User Library: {user_id: User Object}

    def add_book(self, book: Book):
        """Add a new book to the library"""
        if book.book_id not in self.books:
            self.books[book.book_id] = book
            return True, "Book added successfully"
        return False, "Error: Book ID already exists"

    def register_user(self, user: User):
        """Register a new user"""
        if user.user_id not in self.users:
            self.users[user.user_id] = user
            return True, "User registered successfully"
        return False, "Error: User ID already exists"

    def borrow_book(self, user_id: str, book_id: str):
        """Core Logic: Book Borrow Process"""
        if user_id not in self.users:
            return False, "Error: User not found"
        if book_id not in self.books:
            return False, "Error: Book not found"
        
        user = self.users[user_id]
        book = self.books[book_id]

        if book.is_borrowed:
            return False, "Failed: Book is already borrowed"
        
        user.borrow_book(book)
        return True, f"Success! '{book.title}' has been lent to {user.name}"

    def return_book(self, user_id: str, book_id: str):
        """Core Logic: Book Return Process"""
        if user_id not in self.users:
            return False, "Error: User not found"
        if book_id not in self.books:
            return False, "Error: Book not found"
        
        user = self.users[user_id]
        book = self.books[book_id]

        if not book.is_borrowed:
            return False, "Failed: Book is not borrowed"
        
        user.return_book(book)
        return True, f"Success! '{book.title}' has been returned"

    def search_book(self, keyword: str):
        """Search books by title or author"""
        results = []
        for book in self.books.values():
            if keyword.lower() in book.title.lower() or keyword.lower() in book.author.lower():
                results.append(book)
        return results



def main():
    """Library Management System - Main Framework"""
    lib = Library()

    print("=== Initializing Library Data ===")
    lib.add_book(Book("B001", "Python Crash Course", "Eric Matthes"))
    lib.add_book(Book("B002", "Data Structures & Algorithms in Python", "Michael T. Goodrich"))
    lib.add_book(Book("B003", "Fundamentals of Financial Management", "Eugene F. Brigham"))
    lib.register_user(User("U001", "Xiaoming"))
    lib.register_user(User("U002", "Xiaohong"))
    print("Data initialization completed!\n")

    return lib


if __name__ == "__main__":
    library_system = main()
